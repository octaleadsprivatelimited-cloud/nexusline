rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is logged in as the official admin email
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'nexuslineft@gmail.com';
    }

    // Services collection (Public read, Admin write)
    match /services/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Projects collection (Public read, Admin write)
    match /projects/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Gallery collection (Public read, Admin write)
    match /gallery/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Enquiries collection (Public create, Admin read/write/delete)
    match /enquiries/{document} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
